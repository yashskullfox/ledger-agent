## k8s/secret.yaml.template — TEMPLATE ONLY — DO NOT COMMIT WITH REAL VALUES
##
## Copy this file, fill in your values, and apply it once:
##   cp k8s/secret.yaml.template k8s/secret.yaml
##   # edit k8s/secret.yaml
##   kubectl apply -f k8s/secret.yaml
##   rm k8s/secret.yaml   # do not leave real secrets on disk
##
## k8s/secret.yaml is in .gitignore — never commit it.
##
## Alternative (recommended): use your cluster's secret manager
## (AWS Secrets Manager, GCP Secret Manager, Vault) via an ESO or CSI driver.
##
apiVersion: v1
kind: Secret
metadata:
  name: ledger-agent-secrets
  labels:
    app: ledger-agent
    component: secrets
type: Opaque
stringData:
  ## ── LLM provider — supply exactly ONE key (the other stays blank) ──────────
  ## Brain is ours (ledger-agent), API key + billing is yours.
  SPRING_AI_OPENAI_API_KEY: ""        # sk-proj-...   (OpenAI)
  SPRING_AI_ANTHROPIC_API_KEY: ""     # sk-ant-...    (Anthropic)

  ## ── Python financial engine ─────────────────────────────────────────────────
  ## Path inside the container where the SQLite database is stored.
  ## Mount a PersistentVolume at /data and set this to /data/financials.db
  FI_DB_PATH: "/data/financials.db"
  FI_STATEMENTS_DIR: "/data/statements"

  ## ── Optional: remote AI classification backend for transaction tagging ──────
  ## Only needed if FI_AI_BACKEND=openai or gemini (not required for reports)
  FI_OPENAI_API_KEY: ""
  FI_GEMINI_API_KEY: ""

  ## ── Optional: entity/partner display names ──────────────────────────────────
  ## These flow into the CLI and bridge (not the webapp — use ConfigMap for that)
  FI_DEFAULT_ENTITY_NAME: ""
  FI_PARTNER_YASH_NAME: ""
  FI_PARTNER_PARIN_NAME: ""
