# FinancialIntelligence — Git Ignore

# Secrets & config
.env
*.env
.env.local
.env.*.local

# Financial data — NEVER commit real statements or databases
data/
*.db
*.db-wal
*.db-shm
*.pdf
*.PDF

# Python virtual environment
.venv/
venv/
env/
ENV/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Build & distribution
build/
dist/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
pip-wheel-metadata/

# Pytest & coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# Type checking
.mypy_cache/
.pytype/
.pyre/
.ruff_cache/

# Editors & OS
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Logs
*.log
logs/

# Exports (generated output)
data/exports/

# Temporary & scratch files
*.tmp
*.temp
tmp/
temp/
scratch/
sandbox/
experiments/
dev/

# Profiling & benchmarks
*.prof
*.profile
profile_output/
benchmarks/results/
*.lprof

# Property-based testing
.hypothesis/

# Development scripts — manual test scripts not meant for CI
debug_*.py
scratch_*.py
test_manual_*.py
explore_*.py

# Plan files (Wibey AI planning artifacts)
*.plan.md
.wibey/

# Generated CSV / Excel exports (live in data/ but extra safety)
*.xlsx
*.csv
