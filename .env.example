# FinancialIntelligence – Environment Configuration Template
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control (it's in .gitignore).
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   source .env && ./run.sh
#   # OR use python-dotenv (auto-loaded if installed):
#   #   pip install python-dotenv
#   #   The app auto-loads .env when python-dotenv is present

# ── Paths (optional overrides) ────────────────────────────────────────────────
# FI_DATA_DIR=/absolute/path/to/data          # Override data directory
# FI_DB_PATH=/absolute/path/to/financials.db  # Override database path
# FI_MEMORY_FILE=/path/to/memory.json         # Override classification memory

# ── Entity defaults (pre-fill wizard, optional) ───────────────────────────────
# FI_DEFAULT_ENTITY_NAME=MY COMPANY LLC
# FI_DEFAULT_ENTITY_STATE=CA
# FI_DEFAULT_ENTITY_TYPE=LLC

# ── AI Backend (choose one: local, openai, gemini) ────────────────────────────
FI_AI_BACKEND=local

# OpenAI  (required when FI_AI_BACKEND=openai)
# FI_OPENAI_API_KEY=sk-...your-key-here...
# FI_OPENAI_MODEL=gpt-4o-mini

# Google Gemini  (required when FI_AI_BACKEND=gemini)
# FI_GEMINI_API_KEY=AIza...your-key-here...
# FI_GEMINI_MODEL=gemini-1.5-flash

# ── Classification tuning ─────────────────────────────────────────────────────
# FI_AUTO_CLASSIFY_THRESHOLD=85    # 0-100, fuzzy match score for auto-classify

# ── Logging ───────────────────────────────────────────────────────────────────
FI_LOG_LEVEL=INFO
# FI_LOG_FORMAT=rich               # Options: rich (default) | json | plain

# ── Accounting ────────────────────────────────────────────────────────────────
# FI_FISCAL_YEAR_START_MM=1        # 1=January (default)

# ── Tax rates (adjust to match your actual tax situation) ─────────────────────
# All rates are decimals (e.g. 0.048 = 4.8%).  Defaults shown.
# FI_SE_TAX_RATE=0.153             # Self-employment tax: 15.3% (IRS fixed rate)
# FI_FED_INCOME_RATE=0.22          # Federal income tax effective rate (~22%)
# FI_STATE_TAX_RATE=0.048          # State income tax rate (e.g. 4.8% for Missouri MO-PTE)
# FI_QBI_DEDUCTION=0.20            # 20% QBI pass-through deduction (IRC §199A)
# FI_LOCAL_CONFIDENCE_THRESHOLD=0.75  # Min AI confidence to auto-apply classification (0.0–1.0)

# ── Privacy / PII Egress Firewall ─────────────────────────────────────────────
# FI_AI_EGRESS_MODE=redact         # Options: redact (default) | strict | mock | passthrough
# FI_AI_EGRESS_MODE_ACK=           # Set to I_understand_the_risk when mode=passthrough
